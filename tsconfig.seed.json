{
  "compilerOptions": {
    "lib": ["esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": ".seed-out",
    "baseUrl": ".",
    "paths": { "@/*": ["./*"] }
  },
  "include": ["scripts/**/*.ts", "models/**/*.ts", "lib/mongodb.ts", "mock/**/*.json"]
}
